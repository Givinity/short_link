# cp .env.example .env

# PostgreSQL
POSTGRES_USER=givinity
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shortlink

# Redis (кэш записей, TTL 24ч без обращений)
REDIS_URL=redis://localhost:6379/0

# Домен для nginx (локально: localhost, прод: shortly.givinity.net)
DOMAIN=localhost

# --- prod (docker-compose.prod.yaml + внешний docker/traefik) ---
SHORTLY_DOMAIN=shortly.givinity.net

# Email для certbot (локально без Traefik)
CERTBOT_EMAIL=you@example.com
